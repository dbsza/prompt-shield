{
  "name": "prompt-shield",
  "private": true,
  "license": "MIT",
  "packageManager": "yarn@4.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace @prompt-shield/detection-engine run build && yarn workspace @prompt-shield/extension run build",
    "build:wasm": "yarn workspace @prompt-shield/detection-engine run build",
    "build:ext": "yarn workspace @prompt-shield/extension run build",
    "test": "yarn workspaces foreach -A run test",
    "test:e2e": "yarn workspace @prompt-shield/extension run test:e2e",
    "clean": "yarn workspaces foreach -A run clean"
  }
}
